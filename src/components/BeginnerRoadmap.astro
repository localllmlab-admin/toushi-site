---
// 初心者が最初の一歩を踏み出せるように「レベルを選ぶ→最初の1本を読む→学習マップ全体を見る」の3ステップに集約する。
// learn は index.astro 側で order 昇順ソート・reviewed:true のみに絞り込み済みの配列をそのまま受け取る。
const { mapRows, learn } = Astro.props;

const LEVELS = { 1: "入門", 2: "基礎", 3: "実践", 4: "上級" };
const LEVEL_DESC = {
  1: "お金と市場のきほん",
  2: "制度・指標・リスク管理",
  3: "検証と分析の型",
  4: "派生商品・応用理論",
};

const bestGrade = (sources = []) =>
  ["A", "B", "C", "D"].find((g) => sources.some((s) => s.grade === g)) ?? null;

// 初心者の最初の1本＝order昇順で並んだ learn の中から最初に見つかる Lv.1 記事
const featured = learn.find((e) => e.data.level === 1) ?? null;
---
<section class="roadmap-sec" id="roadmap" aria-labelledby="roadmap-h">
  <div class="sec-h">
    <span class="bar"></span>
    <h2 id="roadmap-h">はじめての方はこちらから</h2>
  </div>

  <div class="roadmap">
    <div class="roadmap-step">
      <div class="step-no">STEP 1</div>
      <h3>レベルを選ぶ</h3>
      <div class="level">
        {[1, 2, 3, 4].map((lv) => (
          <a href={`/learn/?lv=${lv}`} class={lv === 1 ? "is-first" : ""}>
            <span class="lv">Lv.{lv}</span>
            {LEVELS[lv]} ― {LEVEL_DESC[lv]}
            {lv === 1 && <span class="badge-first">はじめての方はこちら</span>}
          </a>
        ))}
      </div>
    </div>

    <div class="roadmap-step">
      <div class="step-no">STEP 2</div>
      <h3>最初の1本から読む</h3>
      {featured ? (
        <a class="featured-card" href={`/learn/${featured.slug}/`}>
          <span class="f-thumb">{featured.data.chapter ?? "学ぶ"}</span>
          <span class="f-body">
            <span class="f-title">{featured.data.title}</span>
            <span class="f-meta">
              <span class="lv-tag">Lv.1 入門</span>
              {bestGrade(featured.data.sources) && <span class="grade-tag">出典{bestGrade(featured.data.sources)}</span>}
            </span>
          </span>
        </a>
      ) : (
        <p class="empty">準備中です。</p>
      )}
    </div>

    <div class="roadmap-step">
      <div class="step-no">STEP 3</div>
      <h3>学習マップ全体を見る</h3>
      <div class="map">
        <div class="map-row map-head">
          <span></span>
          {["入門", "基礎", "実践", "上級"].map((l) => <span class="lv-label">{l}</span>)}
        </div>
        {mapRows.map((r) => (
          <div class="map-row">
            <a class="map-ch" href={`/learn/#ch-${r.n}`}>{r.n}. {r.chapter}</a>
            {r.levels.map((has) => <span class={`dot ${has ? "on" : ""}`} aria-hidden="true"></span>)}
          </div>
        ))}
        <a class="map-more" href="/learn/">学習マップを見る ›</a>
      </div>
    </div>
  </div>
</section>

<style>
  .roadmap-sec { padding-top: 1.4rem; }
  .sec-h { display: flex; align-items: center; margin: 0 0 0.6rem; gap: 0.6rem; }
  .sec-h .bar { width: 5px; height: 20px; border-radius: 3px; background: var(--color-accent); flex-shrink: 0; }
  .sec-h h2 { font-size: 1.05rem; font-weight: 800; margin: 0; color: var(--color-text); }

  .roadmap { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.9rem; align-items: start; }
  @media (max-width: 820px) { .roadmap { grid-template-columns: 1fr; } }

  .roadmap-step {
    background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius);
    box-shadow: var(--shadow-card); padding: 1rem 1.05rem;
  }
  .step-no { font-family: var(--font-num); font-size: 0.68rem; font-weight: 800; color: var(--color-accent); letter-spacing: 0.08em; }
  .roadmap-step h3 { font-size: 0.95rem; font-weight: 800; margin: 0.2rem 0 0.7rem; color: var(--color-ink); }

  /* STEP1: レベルカード */
  .level { display: grid; gap: 0.5rem; }
  .level a {
    display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; border: 1.5px solid var(--color-border);
    border-radius: var(--radius); padding: 0.55rem 0.7rem; color: var(--color-text);
    font-weight: 700; font-size: 0.78rem; text-decoration: none; background: var(--color-bg);
  }
  .level a:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .level a.is-first { border-color: var(--color-accent); background: #e8f3fb; }
  .level .lv { font-family: var(--font-num); background: linear-gradient(135deg, var(--color-ink-2), var(--color-ink-3)); color: #fff; font-size: 0.66rem; padding: 0.1rem 0.5rem; border-radius: var(--radius-s); flex-shrink: 0; }
  .badge-first { margin-left: auto; font-size: 0.62rem; font-weight: 800; color: var(--color-accent); }

  /* STEP2: フィーチャー記事 */
  .featured-card { display: flex; gap: 0.7rem; text-decoration: none; align-items: center; }
  .f-thumb {
    width: 88px; height: 60px; flex-shrink: 0; border-radius: 6px; background: linear-gradient(135deg,#2b4a8b,#4a6cb0);
    display: flex; align-items: center; justify-content: center; color: #fff; font-size: 0.66rem; font-weight: 800; text-align: center; padding: 0.3rem;
  }
  .f-body { min-width: 0; }
  .f-title { display: block; font-weight: 800; font-size: 0.88rem; line-height: 1.5; color: var(--color-text); }
  .featured-card:hover .f-title { color: var(--color-accent); text-decoration: underline; }
  .f-meta { display: flex; gap: 0.35rem; margin-top: 0.4rem; }
  .lv-tag, .grade-tag { font-size: 0.66rem; font-weight: 700; border-radius: 3px; padding: 0.05rem 0.5rem; border: 1px solid var(--color-border-strong); color: var(--color-text-muted); }
  .empty { color: var(--color-text-muted); font-size: 0.8rem; margin: 0; }

  /* STEP3: マップ */
  .map-row { display: grid; grid-template-columns: minmax(0, 1fr) repeat(4, 1.4rem); align-items: center; gap: 0.2rem; padding: 0.28rem 0; border-bottom: 1px dashed var(--color-border); }
  .map-row:last-of-type { border-bottom: none; }
  .map-head { font-size: 0.58rem; color: var(--color-text-muted); border-bottom: 1px solid var(--color-border); }
  .lv-label { text-align: center; }
  .map-ch { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.74rem; font-weight: 700; color: var(--color-text); text-decoration: none; }
  .map-ch:hover { color: var(--color-accent); }
  .dot { display: block; width: 0.46rem; height: 0.46rem; margin: 0 auto; border-radius: 50%; border: 1px solid var(--color-border-strong); }
  .dot.on { background: var(--color-accent); border-color: var(--color-accent); }
  .map-more { display: block; text-align: right; font-size: 0.74rem; font-weight: 700; text-decoration: none; margin-top: 0.5rem; }
  .map-more:hover { text-decoration: underline; }
</style>
