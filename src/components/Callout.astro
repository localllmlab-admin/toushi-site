---
/**
 * 注記ボックス。MDX記事内から <Callout type="warn" title="任意見出し">本文</Callout> のように使う。
 * type: "info"（既定・参考情報） | "warn"（注意喚起） | "note"（補足メモ）
 * title: 省略時は type に応じた既定ラベルを表示する。
 */
const { type = "info", title } = Astro.props;
const labels = { info: "参考", warn: "注意", note: "メモ" };
const heading = title ?? labels[type] ?? labels.info;
---
<aside class={`callout callout-${type}`} role="note">
  <p class="callout-title">{heading}</p>
  <div class="callout-body"><slot /></div>
</aside>
<style>
  .callout {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-left: 4px solid var(--color-border);
    background: var(--color-surface-muted);
    border-radius: 6px;
    font-size: 0.95rem;
  }
  .callout-title {
    margin: 0 0 0.4rem;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
  }
  .callout-body :global(p:last-child) { margin-bottom: 0; }
  .callout-info { border-left-color: var(--color-accent); }
  .callout-warn { border-left-color: #d9954a; }
  .callout-warn .callout-title { color: #e0a86f; }
  .callout-note { border-left-color: var(--color-text-muted); }
</style>
