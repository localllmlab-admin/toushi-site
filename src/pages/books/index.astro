---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
const CATS = ["トレード実践", "相場心理", "投資の名著・古典", "インデックス投資・資産形成"];
const all = (await getCollection("books")).filter((e) => e.data.reviewed);
const byCat = CATS.map((c) => ({
  cat: c,
  items: all.filter((e) => e.data.bookCategory === c).sort((a, b) => a.data.order - b.data.order),
})).filter(({ items }) => items.length > 0);
const coverUrl = (isbn10) => `https://images-na.ssl-images-amazon.com/images/P/${isbn10}.09._SL500_.jpg`;
---
<Base
  title="おすすめ書籍｜投資の学び舎（まなびや）"
  description="投資・トレードの定番書・名著を、対象読者レベルと「何に役立つか」つきで紹介します。編集部が内容を確認したうえで、評価を広告報酬で変えずに掲載しています。"
  pagebg={true}
>
  <div class="container-wide">
    <p class="section-label" style="color:var(--color-sec-books)">BOOKS</p>
    <h1>おすすめ書籍</h1>
    <p class="pr-note">本ページにはアフィリエイト広告（PR）が含まれます</p>
    <p class="lead">
      投資・トレードの定番書・名著を、「なぜ読む価値があるのか」「どのレベルの読者向けか」「何に役立つのか」まで踏み込んで紹介します。
      掲載の評価・順序を広告報酬によって変えることはありません（<a href="/policy/">編集方針</a>）。
    </p>
    {byCat.map(({ cat, items }) => (
      <section>
        <h2>{cat}</h2>
        <ul class="book-grid">
          {items.map((e) => (
            <li class="book-item">
              <a href={`/books/${e.slug}/`}>
                <span class="thumb">
                  <img
                    src={coverUrl(e.data.isbn10)}
                    alt={`『${e.data.bookTitle}』書影`}
                    loading="lazy"
                    decoding="async"
                    onerror="this.parentElement.classList.add('noimg')"
                  />
                </span>
                <span class="info">
                  <span class="btitle">{e.data.bookTitle}</span>
                  <span class="bauthor">{e.data.bookAuthor}</span>
                  <span class="blevel">対象: {e.data.readerLevel}</span>
                  <span class="bdesc">{e.data.description}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
    <p class="associate-note">Amazonのアソシエイトとして、投資の学び舎（まなびや）は適格販売により収入を得ています。</p>
  </div>
</Base>
<style>
  .container-wide { padding: 2.4rem 1.25rem 3.5rem; }
  .section-label { font-family: var(--font-mono); font-size: .75rem; letter-spacing: .06em; margin: 0 0 .3rem; }
  .pr-note {
    display: inline-block;
    font-size: .78rem; font-weight: 700;
    color: var(--color-text-muted);
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-s);
    padding: .3em .8em; margin: 0 0 .6rem;
  }
  .lead { max-width: 46em; }
  section { margin-top: 2.2rem; }
  section h2 {
    border-bottom: 2px solid var(--color-sec-books);
    padding-bottom: .3rem; font-size: 1.15rem;
  }
  .book-grid {
    list-style: none; padding: 0; margin: 1rem 0 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 0.9rem;
  }
  .book-item a {
    display: flex; gap: .9rem; height: 100%;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    padding: .85rem .95rem;
    text-decoration: none; color: var(--color-text);
  }
  .book-item a:hover { border-color: var(--color-sec-books); }
  .thumb {
    flex-shrink: 0; width: 72px; aspect-ratio: 5 / 7;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--color-border); border-radius: var(--radius-s);
    background: var(--color-surface); overflow: hidden;
  }
  .thumb img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .thumb.noimg img { display: none; }
  .info { display: flex; flex-direction: column; gap: .2rem; min-width: 0; }
  .btitle { font-weight: 800; font-size: .95rem; line-height: 1.5; }
  .bauthor { font-size: .78rem; color: var(--color-text-muted); }
  .blevel {
    font-size: .72rem; font-weight: 700; color: var(--color-sec-books);
    font-family: var(--font-mono);
  }
  .bdesc {
    font-size: .8rem; color: var(--color-text-muted); line-height: 1.65;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .associate-note {
    font-size: .74rem; color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
    margin-top: 2.4rem; padding-top: .8rem;
  }
</style>
