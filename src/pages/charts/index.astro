---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
const TYPES = ["反転", "継続", "プライスアクション", "インジケーター"];
const all = (await getCollection("charts")).filter((e) => e.data.reviewed);
---
<Base title="チャート図解｜投資の学び場" description="チャートパターン・プライスアクションの図解リファレンス。">
  <div class="container">
    <p class="section-label" style="color:var(--color-sec-charts)">CHARTS</p>
    <h1>チャート図解</h1>
    {TYPES.map((t) => {
      const items = all.filter((e) => e.data.patternType === t);
      return items.length > 0 && (
        <section><h2>{t}</h2>
          <ul>{items.map((e) => <li><a href={`/charts/${e.slug}/`}>{e.data.title}</a></li>)}</ul>
        </section>
      );
    })}
  </div>
  <style>
    .container { padding: 2.4rem 1.25rem 3.5rem; }
    .section-label { font-family: var(--font-mono); font-size: .75rem; letter-spacing: .06em; margin: 0 0 .3rem; }
    ul { list-style: none; padding: 0; }
    li { padding: .5rem 0; border-bottom: 1px solid var(--color-border); }
    section { margin-top: 1.8rem; }
  </style>
</Base>
