---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
const terms = (await getCollection("glossary"))
  .filter((e) => e.data.reviewed)
  .sort((a, b) => (a.data.reading || a.data.term).localeCompare(b.data.reading || b.data.term, "ja"));

// JSON-LD: DefinedTermSet（用語集全体の機械可読化 / WO-TOUSHI-002(a)）
const siteUrl = Astro.site?.href ?? "https://toushi-manabiya.jp/";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  name: "投資の学び舎（まなびや） 用語集",
  url: new URL("/glossary/", siteUrl).href,
  hasDefinedTerm: terms.map((e) => ({
    "@type": "DefinedTerm",
    name: e.data.term,
    url: new URL(`/glossary/${e.slug}/`, siteUrl).href,
  })),
};
---
<Base title="用語集｜投資の学び舎（まなびや）" description="投資・トレード用語をやさしく解説。">
  <div class="container">
    <p class="section-label" style="color:var(--color-sec-glossary)">GLOSSARY</p>
    <h1>用語集</h1>
    {terms.length === 0 ? <p>準備中です。</p> : (
      <dl>{terms.map((e) => (<><dt><a href={`/glossary/${e.slug}/`}>{e.data.term}</a></dt><dd>{e.data.description}</dd></>))}</dl>
    )}
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <style>
    .container { padding: 2.4rem 1.25rem 3.5rem; }
    .section-label { font-family: var(--font-mono); font-size: .75rem; letter-spacing: .06em; margin: 0 0 .3rem; }
    dt { font-weight: 700; margin-top: 1.2rem; border-bottom: 1px solid var(--color-border); padding-bottom: .4rem; }
    dt a { color: var(--color-text); text-decoration: none; }
    dt a:hover { color: var(--color-accent-soft); }
    dd { margin: .3rem 0 0; color: var(--color-text-muted); }
  </style>
</Base>
