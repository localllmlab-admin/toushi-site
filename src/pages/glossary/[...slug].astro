---
import Article from "../../layouts/Article.astro";
import { getCollection } from "astro:content";
export async function getStaticPaths() {
  // reviewed:true のみ公開（未レビュー自動生成物を除外）
  const items = (await getCollection("glossary")).filter((e) => e.data.reviewed);
  return items.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content, headings } = await entry.render();
// 用語集固有: 読み仮名と関連用語（related は用語名の配列。スラッグ解決は名称一致で行う）
const all = (await getCollection("glossary")).filter((e) => e.data.reviewed);
const related = (entry.data.related ?? [])
  .map((name) => all.find((e) => e.data.term === name))
  .filter(Boolean);
---
<Article entry={entry} headings={headings}>
  {entry.data.reading && <p class="reading">読み：{entry.data.reading}</p>}
  <Content />
  {related.length > 0 && (
    <aside class="related">
      <h2>関連用語</h2>
      <ul>{related.map((r) => (
        <li><a href={`/glossary/${r.slug}/`}>{r.data.term}</a> ― {r.data.description}</li>
      ))}</ul>
    </aside>
  )}
</Article>
<style is:global>
  .reading { color: var(--color-text-muted); font-size: .85rem; font-family: var(--font-mono); margin-top: -0.5rem; }
  .related { margin-top: 2rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1rem 1.2rem; }
  .related h2 { font-size: 1rem; margin: 0 0 .5rem; border-bottom: none; }
  .related ul { margin: 0; padding-left: 1.2em; font-size: .9rem; }
  .related li { margin: .35rem 0; }
</style>
