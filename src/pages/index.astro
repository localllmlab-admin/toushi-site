---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { collectTopics } from "../data/topics.mjs";
import BeginnerRoadmap from "../components/BeginnerRoadmap.astro";
import TrustHighlights from "../components/TrustHighlights.astro";

const pub = (arr) => arr.filter((e) => e.data.reviewed);
const learn = pub(await getCollection("learn")).sort((a, b) => a.data.order - b.data.order);
const playbook = pub(await getCollection("playbook"));
const charts = pub(await getCollection("charts"));
const glossary = pub(await getCollection("glossary"));
const books = pub(await getCollection("books"));
const published = learn.length + playbook.length + charts.length + glossary.length + books.length;

// 記事行の共通整形。バッジは frontmatter の実データのみから生成する（根拠のない表示はしない）
const LEVELS = { 1: "入門", 2: "基礎", 3: "実践", 4: "上級" };
const bestGrade = (sources = []) =>
  ["A", "B", "C", "D"].find((g) => sources.some((s) => s.grade === g)) ?? null;
const row = (entry, base, thumbLabel) => ({
  href: `${base}${entry.slug}/`,
  title: entry.data.title,
  thumbLabel,
  level: entry.data.level ? `Lv.${entry.data.level} ${LEVELS[entry.data.level]}` : null,
  grade: bestGrade(entry.data.sources),
  sub: entry.data.chapter ?? entry.data.kind ?? entry.data.patternType ?? null,
  updated: new Date(entry.data.updated),
});

const secLearn = learn.map((e) => row(e, "/learn/", e.data.tags?.[0] ?? "学ぶ"));
const secPlay = playbook.map((e) => row(e, "/playbook/", e.data.kind ?? "定石"));
const secChart = charts.map((e) => row(e, "/charts/", e.data.patternType ?? "図解"));
const secGlos = glossary.map((e) => row(e, "/glossary/", "用語"));
// おすすめ書籍はPRコンテンツのため「注目記事一覧」には混ぜない（教育記事を優先）
const secBooks = books
  .sort((a, b) => a.data.order - b.data.order)
  .map((e) => ({ ...row(e, "/books/", "書籍"), sub: e.data.bookCategory }));

// 注目記事一覧 = 全コレクション横断・更新日降順6件
const topics = [
  ...secLearn.map((r) => ({ ...r, cat: "学ぶ", catClass: "c-learn" })),
  ...secPlay.map((r) => ({ ...r, cat: "手法", catClass: "c-play" })),
  ...secChart.map((r) => ({ ...r, cat: "チャート", catClass: "c-chart" })),
  ...secGlos.map((r) => ({ ...r, cat: "用語", catClass: "c-glos" })),
]
  .sort((a, b) => b.updated - a.updated)
  .slice(0, 6);
const newest = topics.length ? Math.max(...topics.map((t) => t.updated.getTime())) : 0;
const fmt = (d) => d.toLocaleDateString("ja-JP", { month: "numeric", day: "numeric" });

// 学習マップ・ミニチュア（7章 × 4レベル）
const CHAPTERS = [
  "お金と市場の基礎", "商品と制度", "リスク管理", "分析手法",
  "法規制とルール", "行動と心理", "テクノロジーと自動化",
];
const mapRows = CHAPTERS.map((chapter, i) => {
  const items = learn.filter((e) => e.data.chapter === chapter);
  return { n: i + 1, chapter, levels: [1, 2, 3, 4].map((lv) => items.some((e) => e.data.level === lv)) };
});

// 目的別ナビ「テーマから探す」（横断カテゴリ・frontmatter実データのみで分類）
const topicTiles = collectTopics([
  ...learn.map((entry) => ({ collection: "learn", entry })),
  ...playbook.map((entry) => ({ collection: "playbook", entry })),
  ...charts.map((entry) => ({ collection: "charts", entry })),
]).filter((t) => t.items.length > 0);

// 用語ピックアップ（最新の用語1件）
const pickWord = secGlos.length ? glossary.sort((a, b) => new Date(b.data.updated) - new Date(a.data.updated))[0] : null;

const sections = [
  { key: "learn", title: "学ぶ ― 市場と制度の基礎", href: "/learn/", rows: secLearn.slice(0, 4), color: "var(--color-sec-learn)", grad: "linear-gradient(135deg,#2b4a8b,#4a6cb0)" },
  { key: "play", title: "手法・定石 ― 検証つきで学ぶ", href: "/playbook/", rows: secPlay.slice(0, 4), color: "var(--color-sec-playbook)", grad: "linear-gradient(135deg,#1f6e50,#37936f)" },
  { key: "chart", title: "チャートパターン", href: "/charts/", rows: secChart.slice(0, 4), color: "var(--color-sec-charts)", grad: "linear-gradient(135deg,#a3690f,#c98f35)" },
  { key: "books", title: "おすすめ書籍 ― 定番書を選び方つきで", href: "/books/", rows: secBooks.slice(0, 4), color: "var(--color-sec-books)", grad: "linear-gradient(135deg,#8e3b46,#b05f6b)" },
];
---
<Base
  title="投資の学び舎（まなびや）｜相場を、正しく学ぶ。"
  description="投資家・トレーダーのための教育サイト。煽らず、断定せず、一次情報に基づいて、レベル別・出典付きで解説します。"
  pagebg={true}
>
  <section class="hero">
    <div class="container-wide">
      <div class="hero-top">
        <h1>あなたに合う記事から、投資の学習をはじめよう<small>知識ゼロからでも、レベル別・出典付きで安心して学べます</small></h1>
        <div class="stats" role="list">
          <div role="listitem"><b>{published}</b>本 公開中</div>
          <div role="listitem"><b>60</b>本+ 執筆予定</div>
          <div role="listitem"><b>7</b>章×<b>4</b>レベル</div>
        </div>
      </div>
      <a class="hero-cta" href="#roadmap">まずは初心者ガイドを見る</a>
    </div>
  </section>

  <div class="container-wide stack">

    <TrustHighlights published={published} />

    <BeginnerRoadmap mapRows={mapRows} learn={learn} />

    <section class="purpose-nav">
      <div class="sec-h">
        <span class="bar" style="background:var(--color-accent)"></span>
        <h2>テーマから探す</h2>
        <a class="more" href="/topics/">すべてのテーマ ›</a>
      </div>
      <div class="card">
        <div class="topic-grid">
          {topicTiles.map((t) => (
            <a class="topic-tile" href={`/topics/${t.slug}/`}>
              <span class="topic-thumb" style={`background:${t.grad}`}>{t.thumb}</span>
              <span class="topic-name">{t.title}</span>
              <span class="topic-count">{t.items.length}本</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="search-sec">
      <div class="sec-h">
        <span class="bar" style="background:var(--color-text-muted)"></span>
        <h2>キーワードでさがす</h2>
      </div>
      <form class="search-card" action="/search/" method="get" id="hero-search">
        <div class="search-row">
          <div class="f-box">
            <label for="hs-q">キーワード</label>
            <input id="hs-q" name="q" type="text" placeholder="例：複利、NISA、損切り" />
          </div>
          <div class="f-box">
            <label for="hs-ch">章（テーマ）</label>
            <select id="hs-ch">
              <option value="">すべての章</option>
              {CHAPTERS.map((c, i) => <option value={`/learn/#ch-${i + 1}`}>{i + 1}. {c}</option>)}
            </select>
          </div>
          <div class="f-box">
            <label for="hs-lv">レベル</label>
            <select id="hs-lv">
              <option value="">すべてのレベル</option>
              {[1, 2, 3, 4].map((lv) => <option value={`/learn/?lv=${lv}`}>Lv.{lv} {LEVELS[lv]}</option>)}
            </select>
          </div>
          <button class="btn-search" type="submit">記事をさがす</button>
        </div>
        <div class="hot">
          <span>人気の検索：</span>
          {["複利", "損切り", "ダブルトップ", "ボラティリティ", "インサイダー"].map((w) => (
            <a href={`/search/?q=${encodeURIComponent(w)}`}>#{w}</a>
          ))}
        </div>
      </form>
    </section>

    <section>
      <div class="card topics">
        <div class="topics-head">
          <h2>注目記事一覧</h2>
          {newest > 0 && <span class="upd">{fmt(new Date(newest))} 更新</span>}
        </div>
        {topics.length === 0 ? <p class="empty">準備中です。</p> : (
          <ul>
            {topics.map((t, i) => (
              <li>
                <span class={`b-cat ${t.catClass}`}>{t.cat}</span>
                <a href={t.href}>{t.title}</a>
                {i === 0 && <span class="b-new">NEW</span>}
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

    <div class="secondary">
      {sections.map((s) => (
        <section>
          <div class="sec-h">
            <span class="bar" style={`background:${s.color}`}></span>
            <h2>{s.title}</h2>
            <a class="more" href={s.href}>一覧を見る ›</a>
          </div>
          <div class="card">
            {s.rows.length === 0 ? <p class="empty">準備中です。</p> : (
              <ul class="rows">
                {s.rows.map((r) => (
                  <li>
                    <div class="thumb" style={`background:${s.grad}`}>{r.thumbLabel}</div>
                    <div class="row-body">
                      <a class="tt" href={r.href}>{r.title}</a>
                      <div class="meta">
                        {r.grade && <span class="bg bg-src">出典{r.grade}</span>}
                        {r.level && <span class="bg bg-lv">{r.level}</span>}
                        {r.sub && <span class="sub">{r.sub}</span>}
                        <time datetime={r.updated.toISOString()}>{fmt(r.updated)} 更新</time>
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </section>
      ))}

      {pickWord && (
        <section class="card word-sec">
          <h2 class="word-h">用語ピックアップ</h2>
          <dl class="word">
            <dt>{pickWord.data.term}<small>{pickWord.data.reading}</small></dt>
            <dd>{pickWord.data.description}</dd>
          </dl>
          <a class="word-more" href="/glossary/">用語集をひく ›</a>
        </section>
      )}
    </div>

  </div>

  <script is:inline>
    // キーワード検索: キーワードがあれば全文検索へ、空なら選択中の章/レベルの一覧へ
    document.getElementById("hero-search").addEventListener("submit", function (ev) {
      var q = document.getElementById("hs-q").value.trim();
      if (q) return; // そのまま /search/?q= へ
      ev.preventDefault();
      var ch = document.getElementById("hs-ch").value;
      var lv = document.getElementById("hs-lv").value;
      location.href = ch || lv || "/learn/";
    });
  </script>

  <style>
    /* ヒーロー（ブランド青グラデ、検索なし・単一CTA） */
    .hero { background: var(--grad-brand); color: #fff; padding: 1.8rem 0; }
    .hero-top { display: flex; align-items: flex-end; gap: 1.4rem; flex-wrap: wrap; margin-bottom: 1.1rem; }
    .hero h1 { font-size: clamp(1.2rem, 2.6vw, 1.45rem); font-weight: 800; margin: 0; letter-spacing: 0.03em; }
    .hero h1 small { display: block; font-size: 0.75rem; font-weight: 400; opacity: 0.9; margin-top: 0.2rem; }
    .stats { display: flex; gap: 1rem; font-size: 0.7rem; opacity: 0.95; margin-left: auto; }
    .stats b { font-family: var(--font-num); font-size: 1.4rem; font-weight: 700; margin-right: 2px; }
    @media (max-width: 820px) { .stats { margin-left: 0; } }
    .hero-cta {
      display: inline-block; background: var(--grad-cta); color: #fff; font-weight: 800; font-size: 0.95rem;
      border-radius: var(--radius); padding: 0.7rem 1.9rem; text-decoration: none;
      box-shadow: 0 3px 0 var(--color-cta-deep);
    }
    .hero-cta:hover { transform: translateY(1px); box-shadow: 0 2px 0 var(--color-cta-deep); }

    /* 縦積みストーリー型レイアウト */
    .stack { padding-top: 1.25rem; display: grid; gap: 1.6rem; padding-bottom: 1rem; }
    .card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-card); }
    .empty { color: var(--color-text-muted); padding: 0.9rem 1rem; margin: 0; }

    /* セクション見出し（共通） */
    .sec-h { display: flex; align-items: center; margin: 0 0 0.6rem; gap: 0.6rem; }
    .sec-h .bar { width: 5px; height: 20px; border-radius: 3px; }
    .sec-h h2 { font-size: 1.05rem; font-weight: 800; margin: 0; }
    .sec-h .more { margin-left: auto; font-size: 0.78rem; font-weight: 700; text-decoration: none; }
    .sec-h .more:hover { text-decoration: underline; }

    /* テーマから探す（目的別ナビ） */
    .topic-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(215px, 1fr)); gap: 0; }
    .topic-tile {
      display: flex; align-items: center; gap: 0.6rem; text-decoration: none;
      padding: 0.65rem 0.9rem; border-bottom: 1px solid var(--color-border);
      border-right: 1px solid var(--color-border); min-height: 44px;
    }
    .topic-tile:hover { background: var(--color-surface); }
    .topic-tile:hover .topic-name { color: var(--color-accent); text-decoration: underline; }
    .topic-thumb {
      width: 34px; height: 34px; border-radius: 7px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 0.85rem; font-weight: 800;
    }
    .topic-name { font-size: 0.82rem; font-weight: 800; color: var(--color-text); min-width: 0; }
    .topic-count { margin-left: auto; font-family: var(--font-num); font-size: 0.68rem; font-weight: 700; color: var(--color-text-muted); flex-shrink: 0; }

    /* 検索（補助・軽量表示） */
    .search-card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 0.9rem 1rem; }
    .search-row { display: grid; grid-template-columns: 1.4fr 1fr 1fr auto; gap: 0.6rem; }
    @media (max-width: 820px) { .search-row { grid-template-columns: 1fr; } }
    .f-box label { font-size: 0.68rem; font-weight: 700; color: var(--color-text-muted); display: block; margin-bottom: 0.2rem; }
    .f-box input, .f-box select {
      width: 100%; border: 1.5px solid var(--color-border); border-radius: var(--radius);
      padding: 0.5rem 0.7rem; font-size: 0.85rem; background: var(--color-bg);
      color: var(--color-text); font-family: var(--font-sans);
    }
    .btn-search {
      align-self: end; background: var(--grad-cta); color: #fff; font-weight: 800; font-size: 0.88rem;
      border: none; border-radius: var(--radius); padding: 0.6rem 1.6rem; cursor: pointer;
      box-shadow: 0 3px 0 var(--color-cta-deep); white-space: nowrap; font-family: var(--font-sans);
    }
    .btn-search:hover { transform: translateY(1px); box-shadow: 0 2px 0 var(--color-cta-deep); }
    .hot { margin-top: 0.6rem; font-size: 0.72rem; display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
    .hot span { color: var(--color-text-muted); font-weight: 700; }
    .hot a {
      border: 1px solid var(--color-border); border-radius: 20px; padding: 0.1rem 0.7rem;
      color: var(--color-accent); background: var(--color-surface); text-decoration: none;
    }
    .hot a:hover { background: #e8f3fb; }

    /* 注目記事一覧 */
    .topics-head { display: flex; align-items: center; padding: 0.75rem 1rem; border-bottom: 2px solid var(--color-accent); }
    .topics-head h2 { font-size: 1rem; font-weight: 800; color: var(--color-ink); margin: 0; }
    .topics-head h2::before { content: ""; display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--color-cta); margin-right: 0.5rem; }
    .topics-head .upd { margin-left: auto; font-size: 0.7rem; color: var(--color-text-muted); font-family: var(--font-num); }
    .topics ul { list-style: none; margin: 0; padding: 0; }
    .topics li { border-bottom: 1px dashed var(--color-border); padding: 0.6rem 1rem; display: flex; align-items: center; gap: 0.55rem; }
    .topics li:last-child { border-bottom: none; }
    .topics li a { font-weight: 700; color: var(--color-text); font-size: 0.92rem; text-decoration: none; }
    .topics li a:hover { color: var(--color-accent); text-decoration: underline; }
    .b-new { color: #e5322d; font-size: 0.62rem; font-weight: 800; flex-shrink: 0; }
    .b-cat { font-size: 0.64rem; color: #fff; padding: 0.12rem 0.55rem; border-radius: var(--radius-s); flex-shrink: 0; font-weight: 800; }
    .c-learn { background: var(--color-sec-learn); }
    .c-play { background: var(--color-sec-playbook); }
    .c-chart { background: var(--color-sec-charts); }
    .c-glos { background: var(--color-sec-glossary); }

    /* 二次ゾーン（学ぶ/手法/チャート/用語ピックアップ・単一カラム） */
    .secondary { display: grid; gap: 0.2rem; }
    .rows { list-style: none; margin: 0; padding: 0; }
    .rows li { display: flex; gap: 0.85rem; padding: 0.85rem 1rem; border-bottom: 1px solid var(--color-border); }
    .rows li:last-child { border-bottom: none; }
    .rows li:hover { background: var(--color-surface); }
    .thumb {
      width: 100px; height: 68px; flex-shrink: 0; border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 0.7rem; font-weight: 800; letter-spacing: 0.1em;
    }
    .row-body { min-width: 0; }
    .tt { font-weight: 800; font-size: 0.97rem; line-height: 1.55; color: var(--color-text); display: block; text-decoration: none; }
    .tt:hover { color: var(--color-accent); text-decoration: underline; }
    .meta { font-size: 0.72rem; color: var(--color-text-muted); margin-top: 0.35rem; display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap; }
    .meta time { font-family: var(--font-num); }
    .bg { font-size: 0.68rem; font-weight: 700; border-radius: 3px; padding: 0.05rem 0.5rem; border: 1px solid; }
    .bg-src { background: var(--badge-src-bg); color: var(--badge-src-fg); border-color: var(--badge-src-bd); }
    .bg-lv { background: var(--badge-lv-bg); color: var(--badge-lv-fg); border-color: var(--badge-lv-bd); }

    /* 用語ピックアップ */
    .word-sec { padding: 0; }
    .word-h { font-size: 0.88rem; font-weight: 800; color: #fff; background: linear-gradient(120deg, var(--color-ink), var(--color-ink-2)); padding: 0.6rem 0.9rem; margin: 0; }
    .word { padding: 0.8rem 0.9rem 0; margin: 0; }
    .word dt { font-weight: 800; color: var(--color-ink); font-size: 0.98rem; }
    .word dt small { font-weight: 400; color: var(--color-text-muted); font-size: 0.68rem; margin-left: 0.4rem; }
    .word dd { font-size: 0.8rem; color: var(--color-text); margin: 0.35rem 0 0; line-height: 1.7; }
    .word-more { display: block; text-align: right; padding: 0.5rem 0.9rem 0.8rem; font-size: 0.75rem; font-weight: 700; text-decoration: none; }
    .word-more:hover { text-decoration: underline; }
  </style>
</Base>
