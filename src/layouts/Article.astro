---
import Base from "./Base.astro";
import Disclaimer from "../components/Disclaimer.astro";
import Toc from "../components/Toc.astro";
import { getCollection } from "astro:content";
import { topicsOf } from "../data/topics.mjs";
import { existsSync } from "node:fs";
const { entry, headings = [] } = Astro.props;
const { title, description, updated, reviewedAt, sources = [] } = entry.data;

// OGP画像（ops/og/generate_og.mjs で事前生成・コミット済のもののみ参照。未生成はdefaultへ）
const ogName = `${entry.collection}-${entry.slug}`;
const ogImage = existsSync(`public/og/${ogName}.jpg`) ? `/og/${ogName}.jpg` : "/og/default.jpg";

// 同じテーマの記事（テーマ別カテゴリの実データ分類から。根拠のない「おすすめ」は作らない）
const myTopics = topicsOf(entry.collection, entry.data);
let relatedTopic = null;
let related = [];
if (myTopics.length > 0) {
  relatedTopic = myTopics[0];
  const pub = (arr, collection) =>
    arr.filter((e) => e.data.reviewed).map((e) => ({ collection, e }));
  const all = [
    ...pub(await getCollection("learn"), "learn"),
    ...pub(await getCollection("playbook"), "playbook"),
    ...pub(await getCollection("charts"), "charts"),
  ];
  related = all
    .filter(({ collection, e }) =>
      relatedTopic.match(collection, e.data) &&
      !(collection === entry.collection && e.slug === entry.slug))
    .sort((a, b) => new Date(b.e.data.updated) - new Date(a.e.data.updated))
    .slice(0, 4);
}
const upd = new Date(updated).toLocaleDateString("ja-JP");
const rev = reviewedAt ? new Date(reviewedAt).toLocaleDateString("ja-JP") : null;
const gradeLabel = { A: "公的機関", B: "学術", C: "一次発表", D: "報道" };

// JSON-LD（Article 構造化データ：信頼シグナル・発見性）
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  dateModified: new Date(updated).toISOString(),
  inLanguage: "ja",
  publisher: { "@type": "Organization", name: "投資の学び舎（まなびや）" },
};
---
<Base title={`${title}｜投資の学び舎（まなびや）`} description={description} ogImage={ogImage}>
  <article class="container">
    <h1>{title}</h1>
    <p class="meta">
      最終更新: <time datetime={new Date(updated).toISOString()}>{upd}</time>
      {rev && <>　/　レビュー日: <time datetime={new Date(reviewedAt).toISOString()}>{rev}</time> 済</>}
    </p>
    <Toc headings={headings} />
    <div class="body"><slot /></div>

    {sources.length > 0 && (
      <section class="sources">
        <h2>出典・参考</h2>
        <ul>{sources.map((s) => (
          <li>
            <span class={`grade grade-${s.grade}`}>{s.grade}: {gradeLabel[s.grade]}</span>
            <a href={s.url} rel="noopener nofollow">{s.title}</a>
          </li>
        ))}</ul>
        <p class="grade-note"><a href="/policy/">出典等級について（編集方針）</a></p>
      </section>
    )}

    {related.length > 0 && (
      <section class="related">
        <h2>同じテーマの記事</h2>
        <ul>
          {related.map(({ collection, e }) => (
            <li><a href={`/${collection}/${e.slug}/`}>{e.data.title}</a></li>
          ))}
        </ul>
        <p class="related-more"><a href={`/topics/${relatedTopic.slug}/`}>「{relatedTopic.title}」の記事一覧を見る ›</a></p>
      </section>
    )}

    <!-- 免責は常に機械描画。frontmatter では消せない。 -->
    <Disclaimer />
  </article>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <style>
    .container { padding: 2.4rem 1.25rem 3.5rem; }
    .meta {
      color: var(--color-text-muted);
      font-size: 0.85rem;
      font-family: var(--font-mono);
    }
    .body :global(h2) { margin-top: 2.4rem; border-bottom: 1px solid var(--color-border); padding-bottom: .3rem; }
    .body :global(figure.diagram) {
      margin: 1.6rem 0;
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      background: #fff;
      padding: .8rem .8rem .7rem;
    }
    .body :global(figure.diagram img) { width: 100%; height: auto; display: block; }
    .body :global(figure.diagram figcaption) {
      font-size: .78rem;
      color: var(--color-text-muted);
      line-height: 1.6;
      margin-top: .5rem;
    }
    .related { margin-top: 2.5rem; font-size: .92rem; }
    .related h2 { border-bottom: 1px solid var(--color-border); padding-bottom: .3rem; }
    .related ul { list-style: none; padding: 0; margin: .6rem 0 0; }
    .related li { padding: .45rem 0; border-bottom: 1px dashed var(--color-border); }
    .related li a { font-weight: 700; text-decoration: none; }
    .related li a:hover { text-decoration: underline; }
    .related-more { font-size: .82rem; margin-top: .6rem; text-align: right; }
    .related-more a { font-weight: 700; text-decoration: none; }
    .related-more a:hover { text-decoration: underline; }
    .sources { margin-top: 2.5rem; font-size: .9rem; }
    .sources h2 { border-bottom: 1px solid var(--color-border); padding-bottom: .3rem; }
    .sources li { margin: .5rem 0; }
    .sources a { word-break: break-all; }
    .grade {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: 0.02em;
      padding: .15em .55em;
      border-radius: var(--radius-s);
      margin-right: .6em;
      border: 1px solid var(--color-border-strong);
      color: var(--color-text);
    }
    /* A: 公的機関 = 墨紺地・白文字（最上位の信頼シグナル） */
    .grade-A { background: var(--color-ink); border-color: var(--color-ink); color: var(--color-on-ink); }
    /* B/C: 学術・一次発表 = 罫線のみ（アクセント色） */
    .grade-B, .grade-C { background: var(--color-bg); color: var(--color-accent); border-color: var(--color-accent); }
    /* D: 報道 = グレー（事実単独での根拠にしないため一段控えめ） */
    .grade-D { background: var(--color-surface-muted); color: var(--color-text-muted); }
    .grade-note { font-size: .8rem; color: var(--color-text-muted); }
  </style>
</Base>
