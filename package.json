    "draft:dry": "node ops/local/pipeline.mjs --dry-run --no-polish"
  },
  "dependencies": {
    "@astrojs/mdx": "^3.1.0",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "3.2.1",
    "astro": "^4.15.0"
  },
  "devDependencies": {
    "pagefind": "^1.1.0"
  }
}
